# Copy to ".env" and fill in values. Never commit ".env".
# PowerShell (current session):
#   Get-Content .env | ForEach-Object { if ($_ -match '^\s*([A-Za-z_][A-Za-z0-9_]*)=(.*)$') { Set-Item -Path "env:$($matches[1])" -Value $matches[2].Trim().Trim('"') } }

# RunPod (required for scripts/run_runpod_reface_job.py and verify-ghcr-runpod-and-test.ps1)
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# GitHub PAT: needs read:packages for private GHCR images; repo scope for Actions API
GITHUB_TOKEN=

# Image the RunPod template must use (must match registry publish)
GHCR_IMAGE=ghcr.io/cypherhub/runpod-comfyui-worker:latest
GITHUB_REPOSITORY=CypherHub/dockerVast

# Optional: verify-ghcr-runpod-and-test.ps1
SKIP_TEST=
REQUIRE_GHA_SUCCESS=

# Optional: scripts/run_runpod_reface_job.py
USE_ASYNC=
RUNSYNC_WAIT_MS=
WORKFLOW_JSON=
